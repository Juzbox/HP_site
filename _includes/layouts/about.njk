<script>
  fetch('https://api.github.com/repos/juzbox/HP_site/commits/main')
    .then(r => r.json())
    .then(data => {
      const date = new Date(data.commit.author.date);
      const day = date.getDate();
      const suffix = ['th','st','nd','rd'][(day % 10 > 3 || Math.floor(day % 100 / 10) === 1) ? 0 : day % 10] || 'th';
      const month = date.toLocaleString('en-GB', { month: 'long' });
      const year = date.getFullYear();
      document.getElementById('last-updated').textContent = `${day}${suffix} ${month} ${year}`;
    })
    .catch(() => {
      document.getElementById('last-updated').textContent = 'recently';
    });
</script>



</div>

<img class="floating-img" src="{{ floatImage }}" alt="" />

<script>
  const floatingImg = document.querySelector('.floating-img');
if (floatingImg) {
  let x = Math.random() * (window.innerWidth - 200);
  let y = Math.random() * (window.innerHeight - 200);
  let vx = 0.6;
  let vy = 0.4;
  let angle = 0;
  let rotationSpeed = 0.3;
  let dragging = false;
  let offsetX = 0;
  let offsetY = 0;

  if (window.innerWidth > 1200) {
    floatingImg.addEventListener('mouseenter', () => rotationSpeed = 8);
    floatingImg.addEventListener('mouseleave', () => { if (!dragging) rotationSpeed = 0.3; });
  }

  // Mouse drag
  floatingImg.addEventListener('mousedown', (e) => {
    dragging = true;
    offsetX = e.clientX - x;
    offsetY = e.clientY - y;
    floatingImg.style.cursor = 'grabbing';
    e.preventDefault();
  });

  document.addEventListener('mousemove', (e) => {
    if (!dragging) return;
    x = e.clientX - offsetX;
    y = e.clientY - offsetY;
  });

  document.addEventListener('mouseup', () => {
    if (dragging) {
      dragging = false;
      vx = (Math.random() - 0.5) * 2;
      vy = (Math.random() - 0.5) * 2;
      floatingImg.style.cursor = 'grab';
      rotationSpeed = 0.3;
    }
  });

  // Touch drag
  floatingImg.addEventListener('touchstart', (e) => {
    dragging = true;
    offsetX = e.touches[0].clientX - x;
    offsetY = e.touches[0].clientY - y;
    e.preventDefault();
  }, { passive: false });

  document.addEventListener('touchmove', (e) => {
    if (!dragging) return;
    x = e.touches[0].clientX - offsetX;
    y = e.touches[0].clientY - offsetY;
    e.preventDefault();
  }, { passive: false });

  document.addEventListener('touchend', () => {
    if (dragging) {
      dragging = false;
      vx = (Math.random() - 0.5) * 2;
      vy = (Math.random() - 0.5) * 2;
    }
  });

  function animateFloat() {
    if (!dragging) {
      x += vx;
      y += vy;
      if (x <= 0 || x >= window.innerWidth - floatingImg.width) vx *= -1;
      if (y <= 0 || y >= window.innerHeight - floatingImg.height) vy *= -1;
    }
    angle += rotationSpeed;
    floatingImg.style.left = x + 'px';
    floatingImg.style.top = y + 'px';
    floatingImg.style.transform = `rotate(${angle}deg)`;
    requestAnimationFrame(animateFloat);
  }

  floatingImg.style.cursor = 'grab';
  animateFloat();
}


document.querySelectorAll('a').forEach(link => {
  const href = link.getAttribute('href');
  if (href && !href.startsWith('#') && !href.startsWith('mailto:')) {
    link.setAttribute('target', '_blank');
    link.setAttribute('rel', 'noopener noreferrer');
  }
});


</script>